{% extends "layout.html.jinja" %}
{% block title %}StreaMonitor — Settings{% endblock %}
{% block content %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1><i class="bi bi-gear me-2"></i>Settings</h1>
        <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
    <p class="text-muted small">Primary: <code>{{ settings_path }}</code>. Fallback: <code>settings</code> inside <code>{{ config_path }}</code> if using <code>{"streamers": [...], "settings": {...}}</code>. Env vars override both (locked fields).</p>
    {% if message %}
    <div class="alert alert-{{ 'danger' if error else 'success' }}">{{ message }}</div>
    {% endif %}
    <form method="post" action="/settings">
        {% for group in setting_groups %}
        <div class="card bg-dark text-light mb-3">
            <div class="card-header">{{ group.title }}</div>
            <div class="card-body">
                {% for field in group.fields %}
                <div class="mb-3">
                    <label class="form-label" for="f-{{ field.key }}">{{ field.label }}{% if field.locked %} <span class="badge bg-secondary">env</span>{% endif %}</label>
                    {% if field.type == "bool" %}
                    <select class="form-select" id="f-{{ field.key }}" name="{{ field.key }}" {% if field.locked %}disabled{% endif %}>
                        <option value="true" {% if field.value %}selected{% endif %}>Yes</option>
                        <option value="false" {% if not field.value %}selected{% endif %}>No</option>
                    </select>
                    {% elif field.type == "choice" %}
                    <select class="form-select" id="f-{{ field.key }}" name="{{ field.key }}" {% if field.locked %}disabled{% endif %}>
                        {% for c in field.choices %}
                        <option value="{{ c }}" {% if field.value == c %}selected{% endif %}>{{ c }}</option>
                        {% endfor %}
                    </select>
                    {% elif field.type == "password" %}
                    <input type="password" class="form-control" id="f-{{ field.key }}" name="{{ field.key }}" autocomplete="new-password" {% if field.locked %}disabled{% endif %} placeholder="{% if field.locked %}STRMNTR_PASSWORD{% else %}New password (blank = keep){% endif %}">
                    {% if not field.locked %}
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="WEBSERVER_PASSWORD_CLEAR" value="1" id="pwclear">
                        <label class="form-check-label" for="pwclear">Remove password (no login)</label>
                    </div>
                    {% endif %}
                    {% else %}
                    <input class="form-control" id="f-{{ field.key }}" name="{{ field.key }}" value="{{ field.value if field.value is not none else '' }}" {% if field.locked %}disabled{% endif %}>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
        <button type="submit" class="btn btn-primary">Save</button>
    </form>
</div>
{% endblock %}
