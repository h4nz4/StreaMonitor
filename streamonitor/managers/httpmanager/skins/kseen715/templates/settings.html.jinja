<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StreaMonitor — Settings</title>
    <link href="/static/bootstrap@5.3.0/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/static/bootstrap-icons@1.11.0/bootstrap-icons.css">
</head>
<body class="bg-dark text-light">
<div class="container py-4">
    <h1><i class="bi bi-gear me-2"></i>Settings</h1>
    <p class="text-muted small">Primary: <code>{{ settings_path }}</code>. Fallback: <code>settings</code> in <code>{{ config_path }}</code> (wrapper doc). Env overrides locked fields.</p>
    <p><a href="/" class="link-light">Back</a></p>
    {% if message %}
    <div class="alert alert-{{ 'danger' if error else 'success' }}">{{ message }}</div>
    {% endif %}
    <form method="post" action="/settings">
        {% for group in setting_groups %}
        <div class="card bg-secondary mb-3">
            <div class="card-header">{{ group.title }}</div>
            <div class="card-body">
                {% for field in group.fields %}
                <div class="mb-3">
                    <label class="form-label" for="f-{{ field.key }}">{{ field.label }}{% if field.locked and field.key != 'CHB_CF_CLEARANCE' %} <span class="badge bg-dark">env</span>{% endif %}</label>
                    {% if field.type == "bool" %}
                    <select class="form-select" id="f-{{ field.key }}" name="{{ field.key }}" {% if field.locked %}disabled{% endif %}>
                        <option value="true" {% if field.value %}selected{% endif %}>Yes</option>
                        <option value="false" {% if not field.value %}selected{% endif %}>No</option>
                    </select>
                    {% elif field.type == "choice" %}
                    <select class="form-select" id="f-{{ field.key }}" name="{{ field.key }}" {% if field.locked %}disabled{% endif %}>
                        {% for c in field.choices %}
                        <option value="{{ c }}" {% if field.value == c %}selected{% endif %}>{{ c }}</option>
                        {% endfor %}
                    </select>
                    {% elif field.type == "password" %}
                    <input type="password" class="form-control" id="f-{{ field.key }}" name="{{ field.key }}" {% if field.locked %}disabled{% endif %}>
                    {% if not field.locked %}
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" name="WEBSERVER_PASSWORD_CLEAR" value="1" id="pwclear">
                        <label class="form-check-label" for="pwclear">Remove password</label>
                    </div>
                    {% endif %}
                    {% else %}
                    <input class="form-control" id="f-{{ field.key }}" name="{{ field.key }}" value="{{ field.value if field.value is not none else '' }}" {% if field.locked %}disabled{% endif %}>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}
        <button type="submit" class="btn btn-primary">Save</button>
    </form>
</div>
<script src="/static/bootstrap@5.3.0/bootstrap.bundle.min.js"></script>
</body>
</html>
