<h4 class="playing-video">Playing {{ video_to_play.shortname }}</h4>
<video preload="auto" controls="controls">
    <source src="/video?{{ streamer_qs(user, site, filename=video_to_play.filename) }}" type="{{ video_to_play.mimetype }}" />
</video>
<a href="/video?{{ streamer_qs(user, site, filename=video_to_play.filename) }}" download>Download <i class="icon feather icon-download"></i></a>
<input type="hidden" name="play_video" id="play_video" class="streamer-context" value="{{ video_to_play.filename }}">